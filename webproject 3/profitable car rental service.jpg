path d="M23.7 8.7 12 20.42.3 8.71l1.4-1.42L12 17.6 22.3 7.3z"></path></svg></div></div></button></div></div><div class="ADXRXN AzXCPS C6J6UC MEP_vB"><div data-test-id="PinBetterSaveButton" class="ADXRXN" style="pointer-events: auto;"><button aria-label="Save" aria-pressed="false" class="fsprMd _W0I5h O0u6sV" type="button"><div class="dBMCN4 iS__OQ RABojg _W0I5h yVbCXY UOJS4b y4A0gb ap8aAM O0u6sV"><div class="H2DtUH B_eyYB FE_3R1 Tjcf3c kF2VEF sSBu24"><div class="oRZ5_s"><div class="lIkAnG eMU5i5 YfEt3H o5UlW_ hL1e7w">Save</div></div></div></div></button></div></div></div></div></div></div></div></div></div></div></div><div class="ADXRXN _tKaHB wl0pCr zEVE_X"><div class="ADXRXN KDGhSV _tKaHB qtP9fl wl0pCr zEVE_X"><div class="ADXRXN KDGhSV _tKaHB qtP9fl zEVE_X" style="row-gap: 8px; height: 100%;"><div class="ADXRXN _tKaHB zEVE_X" style="position: relative; height: 100%; min-height: 0px;"><style id="closeupMetadataSkeleton-overlay-styles">.closeupMetadataSkeleton__shimmer {
  position: relative;
  overflow: hidden;
  background-color: var(--color-background-tertiary-base, #efefef);
  border-radius: 12px;
  isolation: isolate;
}

.closeupMetadataSkeleton__shimmer::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background-image: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  animation: closeupMetadataSkeleton__shimmer_sweep 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes closeupMetadataSkeleton__shimmer_sweep {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.closeupMetadataSkeleton__shimmer--circle {
  border-radius: 50%;
}

.closeupMetadataSkeleton__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  animation: closeupMetadataSkeleton__overlay_out 240ms ease-out both;
  will-change: opacity, filter;
}

@keyframes closeupMetadataSkeleton__overlay_out {
  0% {
    opacity: 1;
    filter: blur(0);
  }
  100% {
    opacity: 0;
    filter: blur(2px);
  }
}

@media (prefers-reduced-motion: reduce) {
  .closeupMetadataSkeleton__shimmer::after {
    animation: closeupMetadataSkeleton__shimmer_pulse 2s ease-in-out infinite;
    background-image: none;
    background-color: rgba(255, 255, 255, 0.35);
    transform: none;
  }
  @keyframes closeupMetadataSkeleton__shimmer_pulse {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
