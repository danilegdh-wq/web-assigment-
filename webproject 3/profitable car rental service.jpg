  position: relative;
  overflow: hidden;
  background-color: var(--color-background-tertiary-base, #efefef);
  border-radius: 12px;
  isolation: isolate;
}

.closeupMetadataSkeleton__shimmer::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background-image: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  animation: closeupMetadataSkeleton__shimmer_sweep 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes closeupMetadataSkeleton__shimmer_sweep {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.closeupMetadataSkeleton__shimmer--circle {
  border-radius: 50%;
}

.closeupMetadataSkeleton__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  animation: closeupMetadataSkeleton__overlay_out 240ms ease-out both;
  will-change: opacity, filter;
}

@keyframes closeupMetadataSkeleton__overlay_out {
  0% {
    opacity: 1;
    filter: blur(0);
  }
  100% {
    opacity: 0;
    filter: blur(2px);
  }
}

@media (prefers-reduced-motion: reduce) {
  .closeupMetadataSkeleton__shimmer::after {
    animation: closeupMetadataSkeleton__shimmer_pulse 2s ease-in-out infinite;
    background-image: none;
    background-color: rgba(255, 255, 255, 0.35);
    transform: none;
  }
  @keyframes closeupMetadataSkeleton__shimmer_pulse {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }
}</style><div aria-busy="true" aria-label="Loading Pin details" aria-live="polite" data-test-id="closeup-metadata-skeleton" role="status" class="ADXRXN" style="width: 100%;"><div class="H2DtUH KwViV7 bhb3s6 _tKaHB"><div class="oRZ5_s"><div class="H2DtUH KwViV7 z6WAHi _tKaHB"><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 84%; height: 24px;"></div></div><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 52%; height: 24px;"></div></div></div></div><div class="oRZ5_s"><div class="H2DtUH KwViV7 FE_3R1 Tjcf3c qJUqe1 sSBu24"><div class="H2DtUH J6fL34 FE_3R1 Tjcf3c sSBu24"><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer closeupMetadataSkeleton__shimmer--circle" style="width: 48px; height: 48px; border-radius: 50%;"></div></div><div class="oRZ5_s"><div class="H2DtUH KwViV7 z6WAHi _tKaHB"><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 140px; height: 14px;"></div></div><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 88px; height: 12px;"></div></div></div></div></div><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 88px; height: 36px;"></div></div></div><div class="oRZ5_s"><div class="H2DtUH KwViV7 z6WAHi _tKaHB"><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 100%; height: 12px;"></div></div><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 94%; height: 12px;"></div></div><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 72%; height: 12px;"></div></div></div></div><div class="oRZ5_s"><div aria-hidden="true" class="closeupMetadataSkeleton__shimmer" style="width: 100%; height: 48px;"></div></div></div></div></div></div><div class="ADXRXN C6J6UC"><div class="ADXRXN" st